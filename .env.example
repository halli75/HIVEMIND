# Copy to .env for local or testnet runs. Do not commit real secrets.

# 0G Galileo testnet
ZERO_G_RPC_URL=https://evmrpc-testnet.0g.ai
ZERO_G_CHAIN_ID=16602
# 0G Storage indexer for encrypted iNFT strategy upload (Galileo testnet default)
ZERO_G_STORAGE_INDEXER_URL=https://indexer-storage-testnet-standard.0g.ai
ZERO_G_COMPUTE_PROVIDER_ADDRESS=
ZERO_G_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct
# ZG_SERVICE_URL from `0g-compute-cli inference get-secret`, append /v1/proxy
ZERO_G_COMPUTE_API_BASE_URL=
# app-sk-... secret from `0g-compute-cli inference get-secret`
ZERO_G_COMPUTE_BEARER_TOKEN=

# Contract deployment — use your 0G Galileo testnet wallet (same as Compute wallet)
DEPLOYER_PRIVATE_KEY=
# Set after running: cd contracts && npm run deploy:0g:galileo
INFT_CONTRACT_ADDRESS=

# Gensyn / AXL-style local transport
GENSYN_AXL_NODE_ID=
GENSYN_AXL_PEER_URL=
GENSYN_AXL_PRIVATE_KEY=
GENSYN_AXL_TRANSCRIPT_PATH=runs/axl/smoke.jsonl
AXL_NODE_URLS=tcp://localhost:7001,tcp://localhost:7002
AXL_POOL_ID=hivemind-main
HF_TOKEN=
WANDB_API_KEY=

# Uniswap API, Sepolia only
UNISWAP_API_KEY=
UNISWAP_API_BASE_URL=https://trade-api.gateway.uniswap.org
UNISWAP_CHAIN_ID=11155111
UNISWAP_SWAPPER_ADDRESS=
UNISWAP_TOKEN_IN_ADDRESS=
UNISWAP_TOKEN_OUT_ADDRESS=
UNISWAP_AMOUNT_IN_WEI=1000000000000000
UNISWAP_MAX_SLIPPAGE_BPS=50
HIVEMIND_ALLOW_TESTNET_SWAP=false
WALLET_PRIVATE_KEY=
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Local simulation toggles (set to false to use real services)
HIVEMIND_USE_MOCK_0G=true
HIVEMIND_USE_MOCK_GENSYN=true
HIVEMIND_USE_MOCK_UNISWAP=true
# Optional live 0G Compute tuning. HIVEMIND_MOCK_INFERENCE is a legacy alias for HIVEMIND_USE_MOCK_INFERENCE.
HIVEMIND_USE_MOCK_INFERENCE=true
ZERO_G_COMPUTE_TOP_N=10
ZERO_G_COMPUTE_MAX_WORKERS=2
HIVEMIND_SEED_DIR=data/snapshots
HIVEMIND_RUNS_DIR=runs

# Web dashboard
VITE_HIVEMIND_API_URL=http://localhost:8000
